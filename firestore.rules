rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "bounebabdelmalek@gmail.com" ||
        request.auth.token.email == "nonococo1337@gmail.com"
      ) && request.auth.token.email_verified == true;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && 
             (data.email == null || data.email is string) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 500)) &&
             (!('messageCount' in data) || data.messageCount is number) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidMessage(data) {
      return data.role in ['user', 'model'] &&
             data.text is string && data.text.size() < 10000 &&
             (!('image' in data) || data.image == null || (data.image.data is string && data.image.mimeType is string)) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // System rules for founder session
    match /system/founder {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'messageCount', 'createdAt']);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'messageCount', 'createdAt']);

      match /messages/{messageId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidMessage(request.resource.data) && hasOnlyAllowedFields(['role', 'text', 'image', 'createdAt']);
      }
    }
    
    // Allow admin to list all users
    match /users {
      allow list: if isAdmin();
    }
  }
}
